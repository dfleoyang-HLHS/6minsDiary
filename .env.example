# Firebase 服務帳戶 JSON 檔案路徑（後端 API 模式使用）
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# 或直接貼上服務帳戶 JSON 字串（二擇一）
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Firebase Realtime Database URL
FIREBASE_DATABASE_URL=https://sixmins-diary-default-rtdb.asia-southeast1.firebasedatabase.app

# 後端 API 埠號
PORT=3000
